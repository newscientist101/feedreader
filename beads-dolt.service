[Unit]
Description=Beads Dolt SQL Server
Before=feedreader.service

[Service]
Type=simple
User=exedev
Group=exedev
WorkingDirectory=/home/exedev/feedreader/.beads/dolt
ExecStart=/usr/local/bin/dolt sql-server -H 127.0.0.1 -P 3307
Restart=always
RestartSec=5
Environment=HOME=/home/exedev
Environment=USER=exedev
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
